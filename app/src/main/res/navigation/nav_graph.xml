<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="kr.co.example.treeplz.ui.login.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="kr.co.example.treeplz.ui.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_usageDetailsFragment"
            app:destination="@id/usageDetailsFragment" />
        <action
            android:id="@+id/action_homeFragment_to_efficientPromptingFragment"
            app:destination="@+id/efficientPromptingFragment" />
        <action
            android:id="@+id/action_homeFragment_to_usageCalendarFragment"
            app:destination="@id/usageCalendarFragment" />
    </fragment>

    <fragment
        android:id="@+id/usageDetailsFragment"
        android:name="kr.co.example.treeplz.ui.details.UsageDetailsFragment"
        android:label="fragment_usage_details"
        tools:layout="@layout/fragment_usage_details" />

    <fragment
        android:id="@+id/efficientPromptingFragment"
        android:name="kr.co.example.treeplz.ui.prompting.EfficientPromptingFragment"
        android:label="fragment_efficient_prompting"
        tools:layout="@layout/fragment_efficient_prompting" />

    <fragment
        android:id="@+id/usageCalendarFragment"
        android:name="kr.co.example.treeplz.ui.calendar.UsageCalendarFragment"
        android:label="fragment_usage_calendar"
        tools:layout="@layout/fragment_usage_calendar" />

</navigation>